<!-- Файл: MainWindow.xaml -->
<Window x:Class="ParabolaAnimation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Параболическая анимация" Height="450" Width="600">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель управления -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Grid.Row="0">
            <Button Content="Запустить анимацию" Command="{Binding StartCommand}" Width="140" Margin="5"/>
            <Button Content="Обновить счётчик" Command="{Binding RefreshCountCommand}" Width="140" Margin="5"/>
            <TextBlock Text="{Binding LaunchCount, StringFormat='Запусков за час: {0}'}" 
                       VerticalAlignment="Center" FontSize="14" Margin="10,0"/>
        </StackPanel>

        <!-- Область анимации -->
        <Canvas Grid.Row="1" Background="AliceBlue" Margin="5">
            <Ellipse Width="30" Height="30" Fill="Red" 
                     Canvas.Left="{Binding X}" Canvas.Top="{Binding Y}"/>
        </Canvas>
    </Grid>
</Window>